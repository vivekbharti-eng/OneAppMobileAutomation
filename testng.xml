<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Appium Automation Suite" parallel="tests" thread-count="2" verbose="1" configfailurepolicy="skip">

    <listeners>
        <listener class-name="com.automation.listeners.TestSuiteListener"/>
    </listeners>
    
    <!-- Android Test Suite -->
    <test name="Android Tests" parallel="false" preserve-order="true">
        <parameter name="platform" value="android"/>
        <classes>
            <class name="com.automation.runners.TestRunner"/>
        </classes>
    </test>
    
    <!-- iOS Test Suite - Uncomment to run iOS tests -->
    <!--
    <test name="iOS Tests" parallel="false">
        <parameter name="platform" value="ios"/>
        <classes>
            <class name="com.automation.runners.TestRunner"/>
        </classes>
    </test>
    -->
    
</suite>
